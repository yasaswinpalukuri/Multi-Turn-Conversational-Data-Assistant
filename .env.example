# ============================================================
# Multi-Turn Conversational Data Assistant — Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit secrets.
# ============================================================

# ── Ollama ──────────────────────────────────────────────────
# Base URL for your local Ollama instance.
# Default port is 11434. Adjust if you changed it.
OLLAMA_BASE_URL=http://localhost:11434

# Model to use. Must be pulled already: `ollama pull qwen2.5:7b`
# Alternatives tested: llama3.1:8b, mistral:7b, qwen2.5:14b
OLLAMA_MODEL=qwen2.5:7b

# Temperature: 0.0–0.2 for data/code tasks (deterministic).
# Increase to 0.5+ only for conversational/summary responses.
OLLAMA_TEMPERATURE=0.1

# Context window size in tokens.
# 8192 fits ~15 full conversation turns + system prompt + data schema.
# Reduce to 4096 if you hit memory pressure on 8GB VRAM.
OLLAMA_NUM_CTX=8192

# ── Data ────────────────────────────────────────────────────
# Path to the NYC Taxi CSV. Default is relative to project root.
# Download from: https://www.kaggle.com/datasets/elemento/nyc-yellow-taxi-trip-data
# or NYC TLC: https://www.nyc.gov/site/tlc/about/tlc-trip-record-data.page
# For a quick start, grab the 2016-01 parquet and convert:
#   import pandas as pd; pd.read_parquet("yellow_tripdata_2016-01.parquet").sample(50000).to_csv("nyc_taxi_sample.csv", index=False)
DATA_PATH=data/nyc_taxi_sample.csv

# Max rows to load (keeps RAM usage predictable).
# 100_000 rows ≈ 45 MB in memory. Increase if you have headroom.
DATA_MAX_ROWS=100000

# ── ChromaDB ────────────────────────────────────────────────
# Local directory where ChromaDB persists conversation history.
# Created automatically on first run.
CHROMA_PERSIST_DIR=.chroma_store

# Collection name for conversation turns.
CHROMA_COLLECTION=conversation_history

# ── Memory ──────────────────────────────────────────────────
# Number of turns to keep in the rolling in-session window.
# Higher = more context but longer prompts = slower responses.
MEMORY_WINDOW_K=15

# ── Logging ─────────────────────────────────────────────────
# Path for the code-execution audit log.
# All exec() attempts (allowed and blocked) are written here.
EXEC_LOG_PATH=logs/executions.log

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Session ─────────────────────────────────────────────────
# Session ID prefix. A timestamp is appended at runtime.
# Used to namespace ChromaDB documents across sessions.
SESSION_PREFIX=session
